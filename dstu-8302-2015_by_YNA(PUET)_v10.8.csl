<?xml version="1.0" encoding="utf-8"?>
<style xmlns="http://purl.org/net/xbiblio/csl" class="in-text" version="1.0" >
  <info>
    <title>DSTU 8302:2015 Yuriy Nabasov (PUET) 2026</title>
    <id>http://www.zotero.org</id>
    <link href="http://www.zotero.org" rel="self"/>
    <author>
      <name>Yuriy_Nabasov_with_Gemini</name>
      <email>nabasoff@gmail.com</email>
      <uri>https://github.com/Yuriy-Nabasov/zotero-dstu-8302-2015</uri>
    </author>
    <category citation-format="numeric"/>
    <updated>2026-03-08T00:00:00+00:00</updated>
  </info>
  <locale xml:lang="uk">
    <terms>
      <term name="volume" form="short">Вип.</term>
      <term name="issue" form="short">№</term>
      <term name="page" form="short">С.</term>
      <term name="et-al">та ін.</term>
      <term name="and">et al.</term> 
    </terms>
  </locale>
  <locale xml:lang="en">
    <terms>
      <term name="issue" form="short">no.</term>
      <term name="page" form="short">p.</term>
      <term name="volume" form="short">vol.</term>
      <term name="et-al"></term>
    </terms>
  </locale>
  <macro name="author">
    <names variable="author">
      <name name-as-sort-order="all" sort-separator=" " initialize-with="." delimiter=", "/>
      <substitute>
        <names variable="editor"/>
      </substitute>
    </names>
  </macro>
  <macro name="physical-dimensions">
    <choose>
      <if type="book report" match="any">
        <choose>
          <if is-numeric="page">
            <group delimiter=" ">
              <text variable="page"/>
              <choose>
                <if variable="language">
                  <text value="p."/>
                </if>
                <else>
                  <text value="с."/>
                </else>
              </choose>
            </group>
          </if>
          <else>
            <text variable="page"/>
          </else>
        </choose>
      </if>
    </choose>
  </macro>
  <macro name="publisher">
    <group delimiter=" : ">
      <text variable="publisher-place"/>
      <text variable="publisher"/>
    </group>
  </macro>
  <macro name="locators-specific">
    <choose>
      <if variable="language">
        <group delimiter=". ">
          <group delimiter=" ">
            <text value="Vol."></text>
            <text variable="volume"></text>
          </group>
          <group delimiter=" ">
            <text value="No."></text>
            <text variable="issue"></text>
          </group>
            <choose>
          <if type="book report" match="none">
          <group delimiter=" ">
            <text value="P."></text>
            <text variable="page"></text>
          </group>      
          </if>  
            </choose> 
        </group>
      </if>
      <else>
        <group delimiter=". ">
          <group delimiter=" ">
            <text term="volume" form="short"></text>
            <text variable="volume"></text>
          </group>
          <group delimiter=" ">
            <text term="issue" form="short"></text>
            <text variable="issue"></text>
          </group>
          <choose>
          <if type="book report" match="none">
          <group delimiter=" ">
            <text term="page" form="short"></text>
            <text variable="page"></text>
          </group>
          </if>
          </choose>
        </group>
      </else>
    </choose>
  </macro>
  <macro name="language-sort">
    <choose>
      <if variable="language">
        <text value="2"></text>
      </if>
      <else>
        <text value="1"></text>
      </else>
    </choose>
  </macro>
  <citation>
    <layout prefix="[" suffix="]" delimiter=", ">
      <text variable="citation-number"></text>
    </layout>
  </citation>
  <bibliography>
    <sort>
      <key macro="language-sort" sort="ascending"/>
      <key macro="author" sort="ascending"/>
    </sort>
    <layout suffix=".">
      <text variable="citation-number" suffix=". "></text>   
      <choose>
        <if variable="language">
          <names variable="author" suffix=" ">
            <name name-as-sort-order="all" sort-separator=" " initialize-with="." delimiter=", " et-al-min="4" et-al-use-first="3" delimiter-precedes-et-al="never"></name>
            <et-al term="and"></et-al> 
            <substitute>
              <names variable="editor"></names>
            </substitute>
          </names>
        </if>
        <else>
          <names variable="author" suffix=" ">
            <name name-as-sort-order="all" sort-separator=" " initialize-with="." delimiter=", " et-al-min="4" et-al-use-first="3" delimiter-precedes-et-al="never"></name>
            <et-al term="et-al"></et-al> 
            <substitute>
              <names variable="editor"></names>
            </substitute>
          </names>
        </else>
      </choose>
      <text variable="title" suffix=". "></text>    
      <group delimiter=". ">
        <choose>
          <if type="article-journal article-magazine article-newspaper" match="any">
            <text variable="container-title" prefix=" // " font-style="italic"></text>
          </if>
          <else-if type="webpage post-weblog" match="any">
            <text variable="container-title" font-style="italic"/>
          </else-if>
          <else>
            <text variable="container-title" prefix=". " font-style="italic"></text>
          </else>
        </choose>
        <group delimiter=", ">
          <choose>
            <if type="book report" match="any">
              <text macro="publisher"/>
            </if>
          </choose>
          <date variable="issued">
            <date-part name="year"></date-part>
          </date>
        </group>
        <text macro="locators-specific"></text>
      </group>
      <choose>
        <if variable="DOI">
          <text variable="DOI" prefix=". — DOI: "></text>
        </if>
      </choose>
      <text macro="physical-dimensions" prefix=". "></text>
      <choose>
        <if variable="URL">
          <group delimiter=" " prefix=". — URL: " suffix=".">
            <text variable="URL"></text>
            <group prefix=" (" suffix=")">
              <choose>
                <if variable="language">
                  <text value="accessed: "></text>
                </if>
                <else>
                  <text value="дата звернення: "></text>
                </else>
              </choose>
              <date variable="accessed" form="numeric"></date>
            </group>
          </group>
        </if>
      </choose>
    </layout>
  </bibliography>
</style>